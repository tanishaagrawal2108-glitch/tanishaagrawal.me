# Copy to .env.local and fill in from your Sanity project (sanity.io/manage).
# The site works WITHOUT these (it falls back to built-in content); set them to
# turn on the CMS + /admin editor.

# Project ID from Sanity → Project → API (safe to expose; it's public).
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name — usually "production".
NEXT_PUBLIC_SANITY_DATASET=production

# API version (leave as-is unless you know you need a newer one).
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# ONLY needed locally to run `npm run seed` (loads current content into Sanity).
# Create in Sanity → Project → API → Tokens with "Editor" permission.
# Do NOT commit this or add it to Vercel.
SANITY_API_WRITE_TOKEN=
